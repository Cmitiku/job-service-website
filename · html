
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mati Job Service</title>
  <style>
    body {font-family: Arial, sans-serif;margin: 0;background: #f4f6f8;color: #333;}
    header {background: #0f172a;color: white;padding: 25px;text-align: center;}
    nav {background: #1e293b;display: flex;justify-content: center;gap: 20px;padding: 12px;}
    nav a {color: white;text-decoration: none;font-weight: bold;}
    nav a:hover {text-decoration: underline;}
    .container {max-width: 1000px;margin: auto;padding: 20px;}
    .card {background: white;padding: 20px;margin-bottom: 20px;border-radius: 12px;box-shadow: 0 4px 10px rgba(0,0,0,0.05);}
    .job {border-bottom: 1px solid #ddd;padding: 10px 0;}
    button, .apply-btn {background: #2563eb;color: white;border: none;padding: 10px 15px;border-radius: 6px;cursor: pointer;text-decoration: none;display: inline-block;margin-top: 5px;}
    button:hover, .apply-btn:hover {background: #1d4ed8;}
    footer {text-align: center;padding: 15px;background: #0f172a;color: white;}
    input, textarea, select {width: 100%;padding: 10px;margin-top: 8px;margin-bottom: 10px;border-radius: 6px;border: 1px solid #ccc;}
  </style>
</head>
<body>
  <header>
    <h1>Mati Job Service</h1>
    <p>Helping people find local and online job opportunities quickly and easily.</p>
  </header>

  <nav>
    <a href="#jobs">Jobs</a>
    <a href="#apply">Apply</a>
    <a href="#contact">Contact</a>
  </nav>

  <div class="container">
    <div id="jobs" class="card">
      <h2>Available Jobs</h2>

      <div class="job">
        <h3>Website Designer</h3>
        <p>Remote | Part-time</p>
        <a class="apply-btn" href="#apply">Apply Now</a>
      </div>

      <div class="job">
        <h3>Data Entry Clerk</h3>
        <p>Remote | Flexible Hours</p>
        <a class="apply-btn" href="#apply">Apply Now</a>
      </div>

      <div class="job">
        <h3>Customer Support Agent</h3>
        <p>Online | Full-time</p>
        <a class="apply-btn" href="#apply">Apply Now</a>
      </div>
    </div>

    <!-- Job Application Form with CV Upload -->
    <div id="apply" class="card">
      <h2>Job Application Form</h2>
      <form action="https://formsubmit.co/mmitiku6878@gmail.com" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_subject" value="New Job Application - Mati Job Service">
        <input type="hidden" name="_captcha" value="false">

        <label>Full Name</label>
        <input type="text" name="name" required>

        <label>Email Address</label>
        <input type="email" name="email" required>

        <label>Phone Number</label>
        <input type="text" name="phone" required>

        <label>Select Job</label>
        <select name="job">
          <option>Website Designer</option>
          <option>Data Entry Clerk</option>
          <option>Customer Support Agent</option>
        </select>

        <label>Upload CV (PDF or DOC)</label>
        <input type="file" name="attachment" accept=".pdf,.doc,.docx" required>

        <label>Message</label>
        <textarea name="message" placeholder="Write a short message..."></textarea>

        <button type="submit">Submit Application</button>
      </form>
    </div>

    <div id="contact" class="card">
      <h2>Contact</h2>
      <p>Email: mmitiku6878@gmail.com</p>
      <a class="apply-btn" href="mailto:mmitiku6878@gmail.com">Send Email</a>
    </div>
  </div>

  <footer>
    <p>© 2026 Mati Job Service | All Rights Reserved</p>
  </footer>
</body>
</html>
